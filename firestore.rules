rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // HELPER FUNCTIONS
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Role-Based helper
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == "goyalelectrocare@gmail.com";
    }

    function isDoctor() {
      return isSignedIn() && userExists() && getProfile().get('role', 'unassigned') == 'doctor';
    }

    function isPharmacist() {
      return isSignedIn() && userExists() && getProfile().get('role', 'unassigned') == 'pharmacist';
    }

    function isStaff() {
      return isAdmin() || (isSignedIn() && userExists() && getProfile().get('status', 'pending') == 'active' && (getProfile().get('role', 'unassigned') in ['doctor', 'pharmacist']));
    }

    function isActiveDoctor() {
      return isDoctor() && getProfile().get('status', 'pending') == 'active';
    }

    function isActivePharmacist() {
      return isPharmacist() && getProfile().get('status', 'pending') == 'active';
    }

    // ===============================================================
    // BASE DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // USERS COLLECTION (Global Registry)
    // ===============================================================
    match /users/{userId} {
      allow get: if isValidId(userId) && (request.auth.uid == userId || isAdmin() || isStaff());
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.get('role', 'unassigned') in ['doctor', 'pharmacist'] ||
        (isStaff() && resource.data.get('role', 'unassigned') == 'patient')
      );
      
      allow create: if isValidId(userId) && userId == request.auth.uid && (
        incoming().keys().hasAll(['uid', 'email', 'role', 'status', 'createdAt']) &&
        incoming().role in ['patient', 'doctor', 'pharmacist', 'unassigned']
      );
      
      allow update: if isValidId(userId) && (
        isAdmin() || 
        (userId == request.auth.uid && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'medical', 'role', 'status'])
        ))
      );

      match /reminders/{reminderId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // ===============================================================
    // PROFESSIONAL COLLECTIONS
    // ===============================================================
    match /doctors/{userId} {
      allow read, write: if isSignedIn();
    }

    match /pharmacies/{userId} {
      allow read, write: if isSignedIn();
    }

    // ===============================================================
    // CLINICAL COLLECTIONS
    // ===============================================================
    
    match /patients/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (
        resource.data.doctorId == request.auth.uid || 
        resource.data.patientId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.doctorId == request.auth.uid || 
        resource.data.patientId == request.auth.uid || 
        isAdmin()
      );
    }

    match /prescriptions/{prescriptionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Explicitly allowed for pharmacists fetching arrays
      allow create: if isSignedIn() && isStaff();
      allow update: if isSignedIn() && (isAdmin() || isStaff());
    }

    match /inventory/{inventoryId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (isAdmin() || isStaff());
    }

    match /clinicalNotes/{noteId} {
      allow read: if isSignedIn() && (isAdmin() || isStaff() || resource.data.patientId == request.auth.uid);
      allow create: if isSignedIn() && isStaff();
      allow update, delete: if isSignedIn() && (isAdmin() || isStaff());
    }

    match /examResults/{resultId} {
      allow read: if isSignedIn() && (isAdmin() || isStaff() || resource.data.patientId == request.auth.uid);
      allow create: if isSignedIn() && isStaff();
      allow update, delete: if isSignedIn() && (isAdmin() || isStaff());
    }

    match /consultations/{consultationId} {
      allow read, write: if isSignedIn();
    }

    match /chatRooms/{roomId} {
      allow read, write: if isSignedIn();
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /emergency_calls/{callId} {
      allow read: if isSignedIn(); // Allow all signed in users to read (safety first)
      allow create: if isSignedIn() && 
        incoming().patientId == request.auth.uid &&
        incoming().status == 'active';
      allow update: if isSignedIn();
    }
  }
}
