rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // HELPER FUNCTIONS
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Role-Based helper
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "goyalelectrocare@gmail.com" ||
        getProfile().get('role', 'unassigned') == 'admin'
      ); 
    }

    function isDoctor() {
      return isSignedIn() && getProfile().get('role', 'unassigned') == 'doctor';
    }

    function isPharmacist() {
      return isSignedIn() && getProfile().get('role', 'unassigned') == 'pharmacist';
    }

    function isActiveDoctor() {
      return isDoctor() && getProfile().get('status', 'pending') == 'active';
    }

    function isActivePharmacist() {
      return isPharmacist() && getProfile().get('status', 'pending') == 'active';
    }

    // ===============================================================
    // BASE DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // USERS COLLECTION (Global Registry)
    // ===============================================================
    match /users/{userId} {
      allow get: if isValidId(userId) && (request.auth.uid == userId || isAdmin());
      
      // Admins can list anyone. 
      // Doctors/Pharmacists can only list patients.
      allow list: if isSignedIn() && (
        isAdmin() || 
        ((isActiveDoctor() || isActivePharmacist()) && resource.data.get('role', 'unassigned') == 'patient')
      );
      
      allow create: if isValidId(userId) && userId == request.auth.uid && (
        incoming().keys().hasAll(['uid', 'email', 'role', 'status', 'createdAt']) &&
        incoming().uid == request.auth.uid &&
        incoming().role in ['patient', 'doctor', 'pharmacist', 'admin', 'unassigned'] &&
        incoming().status in ['active', 'pending', 'rejected']
      );
      
      allow update: if isValidId(userId) && (
        // Admin can update status and role
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'role', 'updatedAt'])) ||
        // User can update profile details but NOT status/role (unless starting as unassigned)
        (userId == request.auth.uid && (
          (existing().role == 'unassigned' && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'status', 'displayName', 'photoURL', 'updatedAt', 'medical'])) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'medical']))
        ))
      );

      // Subcollections like reminders
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // ===============================================================
    // PROFESSIONAL COLLECTIONS
    // ===============================================================
    match /doctors/{userId} {
      allow read: if isSignedIn();
      allow write: if isValidId(userId) && userId == request.auth.uid;
    }

    match /pharmacies/{userId} {
      allow read: if isSignedIn();
      allow write: if isValidId(userId) && userId == request.auth.uid;
    }

    // ===============================================================
    // CLINICAL COLLECTIONS
    // ===============================================================
    
    // Patient Profile (Extended Data)
    match /patients/{userId} {
      allow get: if isValidId(userId) && (
        request.auth.uid == userId || 
        isActiveDoctor() || 
        isActivePharmacist() || 
        isAdmin()
      );
      allow list: if isSignedIn() && (
        isActiveDoctor() || 
        isActivePharmacist() || 
        isAdmin()
      );
      allow create, update: if isValidId(userId) && (request.auth.uid == userId || isAdmin());
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow get: if isValidId(appointmentId) && (
        existing().doctorId == request.auth.uid || 
        existing().patientId == request.auth.uid || 
        isAdmin()
      );
      allow list: if isSignedIn() && (
        resource.data.doctorId == request.auth.uid || 
        resource.data.patientId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isValidId(appointmentId) && (
        (isActiveDoctor() && incoming().doctorId == request.auth.uid) || 
        (incoming().patientId == request.auth.uid)
      );
      
      allow update: if isValidId(appointmentId) && (
        existing().doctorId == request.auth.uid || 
        existing().patientId == request.auth.uid || 
        isAdmin()
      );
    }

    // Prescriptions
    match /prescriptions/{prescriptionId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid || 
        isActivePharmacist() || 
        isAdmin()
      );
      
      allow create: if isValidId(prescriptionId) && isActiveDoctor() && 
                    incoming().doctorId == request.auth.uid;
      
      allow update: if isValidId(prescriptionId) && (
        (isActivePharmacist() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'pharmacyId', 'pharmacyName'])) ||
        (isActiveDoctor() && existing().doctorId == request.auth.uid) ||
        isAdmin()
      );
    }

    // ===============================================================
    // UTILITY COLLECTIONS
    // ===============================================================
    match /consultations/{consultationId} {
       allow read, write: if isSignedIn(); 
    }

    match /clinicalNotes/{noteId} {
      allow get: if isValidId(noteId) && (
        resource.data.patientId == request.auth.uid || 
        isActiveDoctor() || 
        isAdmin()
      );
      allow list: if isSignedIn() && (
        resource.data.patientId == request.auth.uid || 
        isActiveDoctor() || 
        isAdmin()
      );
      allow create: if isValidId(noteId) && isActiveDoctor() && 
                    incoming().doctorId == request.auth.uid;
      allow update, delete: if isValidId(noteId) && (
        (isActiveDoctor() && existing().doctorId == request.auth.uid) ||
        isAdmin()
      );
    }

    match /examResults/{resultId} {
      allow get: if isValidId(resultId) && (
        resource.data.patientId == request.auth.uid || 
        isActiveDoctor() || 
        isAdmin()
      );
      allow list: if isSignedIn() && (
        resource.data.patientId == request.auth.uid || 
        isActiveDoctor() || 
        isAdmin()
      );
      allow create: if isValidId(resultId) && isActiveDoctor();
      allow update, delete: if isValidId(resultId) && (isActiveDoctor() || isAdmin());
    }

    match /chatRooms/{roomId} {
      allow read, write: if isSignedIn();
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
